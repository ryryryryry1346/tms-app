# --- Database ---
MYSQL_DATABASE_URL=mysql://root:password@127.0.0.1:3306/tms_app

# --- Runtime ---
NODE_ENV=production

# --- Auth (better-auth) ---
# REQUIRED in production. Must be at least 32 characters.
# Generate one with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
# REQUIRED in production. Public base URL of the app; used to build
# verification and password-reset links. No trailing slash.
BETTER_AUTH_URL=https://tms.example.com

# --- Email (Resend) ---
# REQUIRED: email verification is mandatory, so sign-up fails without this.
RESEND_API_KEY=re_your_api_key
# Sender shown on verification / reset emails. Must be a verified Resend domain.
RESEND_FROM=TMS <no-reply@example.com>

# --- Media (Cloudinary) ---
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
# Optional explicit Cloudinary variables instead of CLOUDINARY_URL:
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret
